{
  "name": "smartcampus-nexus",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "clean-ports": "kill-port 3000 5000",
    "dev": "npm run clean-ports && npm run dev:all",
    "dev:backend": "npm --prefix backend run dev",
    "dev:react": "npm --prefix frontend-react start",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:react\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "kill-port": "^2.0.1"
  }
}
